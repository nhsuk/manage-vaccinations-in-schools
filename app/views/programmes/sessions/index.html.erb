<%= content_for :page_title, "#{@programme.name} – #{t(".title")}" %>

<% content_for :before_main do %>
  <%= render AppBreadcrumbComponent.new(items: [
                                          { text: t("dashboard.index.title"), href: dashboard_path },
                                          { text: t("programmes.index.title"), href: programmes_path },
                                          { text: @programme.name, href: programme_overview_path(@programme, @academic_year) },
                                        ]) %>
<% end %>

<%= render "programmes/heading" %>

<%= render AppProgrammeNavigationComponent.new(@programme, @academic_year, active: :sessions) %>

<div class="nhsuk-grid-row">
  <div class="app-grid-column-filters">
    <%= render AppSessionSearchFormComponent.new(
          @form,
          url: programme_sessions_path,
          programmes: @programmes,
          academic_years: false,
        ) %>
  </div>

  <div class="app-grid-column-results">
    <%= render AppSearchResultsComponent.new(@pagy, label: "sessions") do %>
      <% @sessions.each do |session| %>
        <%= render AppSessionCardComponent.new(
              session, patient_count: @patient_count_by_session_id.fetch(session.id, 0),
            ) %>
      <% end %>
    <% end %>
  </div>
</div>
