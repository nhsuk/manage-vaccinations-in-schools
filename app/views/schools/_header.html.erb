<%= h1 @school.name, class: "nhsuk-u-margin-bottom-2" %>

<p class="nhsuk-caption-l nhsuk-u-margin-bottom-4">
  <%= format_address_single_line(@school) %>
</p>

<%= render AppSecondaryNavigationComponent.new do |nav|
      nav.with_item(
        href: school_patients_path(@school),
        text: t("schools.patients.title"),
        selected: request.path == school_patients_path(@school),
      )
    
      nav.with_item(
        href: school_sessions_path(@school),
        text: t("schools.sessions.title"),
        selected: request.path == school_sessions_path(@school),
      )
    end %>
