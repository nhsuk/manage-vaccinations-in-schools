<% content_for :before_main do %>
  <%= govuk_back_link(href: @back_link_path) %>
<% end %>

<% if @draft_school.editing? %>
  <%= h1 "Edit school site" %>
<% else %>
  <%= h1 "Check and confirm" %>
<% end %>

<%= render AppCardComponent.new do |card| %>
  <% card.with_heading { "Site details" } %>

  <% change_links = @draft_school.editing? ? {
       name: wizard_path(:details),
       address: wizard_path(:details),
     } : { urn: wizard_path(:school) } %>

  <%= render AppSchoolSummaryComponent.new(@draft_school, change_links:) %>
<% end %>

<%= form_with(model: @draft_school, url: wizard_path, method: :put) do |form| %>
  <%= form.govuk_submit @draft_school.editing? ? "Save changes" : "Add site" %>
<% end %>