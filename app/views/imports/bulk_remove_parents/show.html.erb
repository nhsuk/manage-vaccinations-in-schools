<% content_for :before_main do %>
  <%= render AppBreadcrumbComponent.new(items: [
                                          { text: t("dashboard.index.title"), href: dashboard_path },
                                          { text: t("imports.index.title"), href: imports_path },
                                        ]) %>
<% end %>

<%= h1 t("imports.bulk_remove_parents.show.title") %>

<%= form_with model: @form,
              url: imports_bulk_remove_parents_path(import_type: @import.class.name.underscore, import_id: @import.id),
              builder: GOVUKDesignSystemFormBuilder::FormBuilder,
              local: true do |f| %>
  <% if @consents.any? %>

    <%= simple_format(t("imports.bulk_remove_parents.show.consents_warning")) %>

    <%= govuk_table(html_attributes: { class: "nhsuk-table-responsive" }) do |table| %>
      <%= table.with_head do |head|
            head.with_row do |row|
              row.with_cell(text: "Response")
              row.with_cell(text: "Response date")
              row.with_cell(text: "Programme")
            end
          end %>

      <%= table.with_body do |body| %>
        <% @consents.each do |consent| %>
          <%= body.with_row do |row| %>
            <%= row.with_cell do %>
              <span class="nhsuk-table-responsive__heading">Response</span>
              <span>
                <%= consent.parent_relationship.label_with_parent %>
                <br>
                <span class="nhsuk-u-secondary-text-colour nhsuk-u-font-size-16">
                  for <%= consent.patient.full_name %>
                </span>
              </span>
            <% end %>

            <%= row.with_cell do %>
              <span class="nhsuk-table-responsive__heading">Response date</span>
              <%= consent.created_at.to_date.to_fs(:long) %>
            <% end %>

            <%= row.with_cell do %>
              <span class="nhsuk-table-responsive__heading">Programme</span>
              <%= tag.strong(
                    consent.programme.name,
                    class: "nhsuk-tag app-tag--attached nhsuk-tag--white",
                  ) %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%= render AppPaginationComponent.new(pagy: @pagy) %>

    <%= f.govuk_radio_buttons_fieldset :remove_option, legend: nil do %>
      <%= f.govuk_radio_button :remove_option,
                               "unconsented",
                               label: { text: t("imports.bulk_remove_parents.show.options.unconsented_only.description") },
                               hint: { text: t("imports.bulk_remove_parents.show.options.unconsented_only.hint_text") },
                               checked: false %>

      <%= f.govuk_radio_button :remove_option,
                               "all",
                               label: { text: t("imports.bulk_remove_parents.show.options.all.description") },
                               hint: { text: t("imports.bulk_remove_parents.show.options.all.hint_text") },
                               checked: false %>
    <% end %>
  <% end %>

  <div class="nhsuk-button-group">
    <%= f.govuk_submit t("imports.bulk_remove_parents.show.buttons.continue"), warning: true, class: "govuk-button govuk-button--warning" %>
    <%= link_to t("imports.bulk_remove_parents.show.buttons.cancel"), polymorphic_path(@import), secondary: true %>
  </div>
<% end %>