#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
  LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
  export LD_PRELOAD
fi

for var in $(env | cut -d= -f1); do
  if [ "${!var}" = "CHANGE_ME" ]; then
    unset "$var"
  fi
done

# When starting the container then create or migrate existing database
if [ "$1" == "./bin/docker-start" ]; then
  ./bin/rails db:prepare:ignore_concurrent_migration_exceptions
  ./bin/rails feature_flags:seed

  # To support running end to end tests on PRs that require feature flags to
  #  be enabled that aren't currently enabled in the base branch.
  if [ "$RAILS_ENV" == "development" ]; then
    ./bin/rails feature_flags:enable_for_development
  fi
fi

exec "${@}"
