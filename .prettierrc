{
  "plugins": ["@prettier/plugin-ruby"],
  "overrides": [
    {
      "files": ["*.rb", "*.md"],
      "options": {
        "trailingComma": "none"
      }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": {
        "printWidth": 100,
        "proseWrap": "always"
      }
    }
  ]
}
