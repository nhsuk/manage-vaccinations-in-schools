amends "package://github.com/jdx/hk/releases/download/v0.7.5/hk@0.7.5#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v0.7.5/hk@0.7.5#/builtins.pkl"

local linters = new Mapping<String, Step> {
    ["brakeman"] = new LinterStep {
        check = "bin/brakeman --quiet --no-summary --no-pager"
    }

    ["prettier"] = new LinterStep {
        check = "bin/prettier --check --ignore-unknown {{ files }}"
        fix = "bin/prettier --write --list-different --ignore-unknown {{ files }}"
    }

    ["rubocop"] = new LinterStep {
        glob = List("**/*.rb")
        check = "bin/rubocop {{ files }}"
        fix = "bin/rubocop --fix {{ files }}"
    }

    ["rufo"] = new LinterStep {
        glob = List("**/*.erb")
        exclude = List("**/layouts/*")
        check = "bin/rufo --check {{ files }}"
        fix = "bin/rufo {{ files }}"
    }

    ["terraform"] = builtins.terraform

    ["tf_lint"] = new LinterStep {
        glob = List("**/*.tf")
        check = "tflint --chdir=terraform --recursive"
        fix = "tflint --chdir=terraform --recursive --fix"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        steps = new {
            ["stash"] = new StashStep {}
            ...linters
        }
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
